# Copy this file to .env and fill in development values.
# .env is gitignored; .env.example is committed as the template.

# Postgres credentials (used by the postgres service and, later, the app).
POSTGRES_USER=opengate
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=opengate

# Grafana admin password. Anonymous users get the Viewer role without
# logging in; administrative changes require logging in as admin with
# this password.
GRAFANA_ADMIN_PASSWORD=change_me_in_local_env
